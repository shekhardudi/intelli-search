{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Intelli-Search Intelligent Search – operational dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "rate(intelli_search_search_requests_total[1m])",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "title": "Search Requests / sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "none",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 5},
            {"color": "red", "value": 20}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "intelli_search_active_search_requests",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "title": "Active Requests",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "reqps",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.1},
            {"color": "red", "value": 0.5}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "rate(intelli_search_zero_result_queries_total[5m])",
          "legendFormat": "Zero-result rate",
          "refId": "A"
        }
      ],
      "title": "Zero-Result Rate",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 4,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(intelli_search_search_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(intelli_search_search_latency_ms_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(intelli_search_search_latency_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Search Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(intelli_search_opensearch_query_duration_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(intelli_search_opensearch_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "OpenSearch Query Duration (p50 / p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "title": "LLM (Intent Classifier)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "rate(intelli_search_llm_calls_total[1m])",
          "legendFormat": "{{model}} ({{status}})",
          "refId": "A"
        }
      ],
      "title": "LLM Calls / sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_uid}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 7,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(intelli_search_llm_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(intelli_search_llm_latency_ms_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "LLM Latency (p50 / p95)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["intelli-search", "search", "otel"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "prometheus_uid",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Intelli-Search Intelligent Search",
  "uid": "intelli-search-v1",
  "version": 1
}

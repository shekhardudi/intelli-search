# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# OpenSearch Configuration
# ============================================================================
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Pas*here
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_NAME=companies-new

# ============================================================================
# OpenAI / Azure OpenAI Configuration
# ============================================================================

# For OpenAI
OPENAI_API_KEY=sk-your-api-key-here
# Model overrides (optional — defaults shown)
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_MINI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# For Azure OpenAI (enable by setting API_BASE to Azure endpoint)
# OPENAI_API_BASE=https://your-resource.openai.azure.com/
# OPENAI_API_VERSION=2024-02-15-preview
# OPENAI_DEPLOYMENT_NAME=gpt-4-deployment

# ============================================================================
# Tavily Web Search
# Enables real-time web context for agentic search queries.
# Get your key at https://app.tavily.com
# ============================================================================
TAVILY_API_KEY=tvly-your-api-key-here

# ============================================================================
# Search Configuration
# ============================================================================
SEARCH_TIMEOUT=30

# ============================================================================
# Features
# ============================================================================
ENABLE_SEMANTIC_SEARCH=true
ENABLE_AGENTIC_SEARCH=true
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_CACHING=true
ENABLE_TRACING=true

# ============================================================================
# Intent Classifier
# ============================================================================
CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
CLASSIFIER_TIMEOUT=10

# ============================================================================
# Observability (OpenTelemetry)
# ============================================================================
OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=intelli-search

